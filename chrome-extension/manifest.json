{
  "manifest_version": 3,
  "name": "Review & Handoff",
  "version": "1.0.0",
  "description": "Adicione comentários em qualquer protótipo Vercel",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_end"
    }
  ],
  "permissions": ["activeTab", "storage"],
  "host_permissions": [
    "https://ikmtbhnfipatxecxpyfa.supabase.co/*"
  ]
}
